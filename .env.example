# ====================
# Ultra-AI- Environment Example
# Copy this file to .env and fill in your real secrets!
# ====================

# --- AI Provider Keys ---
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
MISTRAL_API_KEY=your-mistral-key-here
PERPLEXITY_API_KEY=your-perplexity-key-here

# --- South African Government Integrations ---
DHA_API_KEY=your-dha-api-key-here
DHA_NPR_API_KEY=your-npr-api-key-here
DHA_NPR_BASE_URL=https://npr-prod.dha.gov.za/api/v1
DHA_ABIS_API_KEY=your-abis-api-key-here
DHA_ABIS_BASE_URL=https://abis-prod.dha.gov.za/api/v1
ICAO_PKD_API_KEY=your-icao-pkd-key-here
ICAO_PKD_BASE_URL=https://pkddownloadsg.icao.int
SAPS_CRC_API_KEY=your-saps-crc-key-here
SAPS_CRC_BASE_URL=https://crc-api.saps.gov.za/v1

# --- Railway Cloud Integration (for auto-scaling, etc.) ---
RAILWAY_PROJECT_TOKEN=your-railway-project-token-here
RAILWAY_TOKEN=your-railway-account-token-here

# --- Other integrations as needed ---
# EXAMPLE_API_KEY=...

# ====================
# Instructions:
# 1. Copy this file as `.env` in the project root.
# 2. Fill in all API keys from your providers and partners.
# 3. Do NOT commit your real `.env` file to git (it is in .gitignore).
# 4. If you don't have a key, leave it blank - the app will gracefully warn you and disable that feature.
# ====================